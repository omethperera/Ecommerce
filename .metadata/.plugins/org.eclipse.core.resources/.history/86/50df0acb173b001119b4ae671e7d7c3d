import { useEffect, useState } from "react";
import { useNavigate } from "react-router-dom";
import { getAdminOrders, updateAdminOrderStatus } from "../api/orderApi";

function AdminOrdersPage() {
  const [orders, setOrders] = useState([]);
  const sellerId = localStorage.getItem("userId");
  const navigate = useNavigate();

  useEffect(() => {
    const fetchOrders = async () => {
      try {
        const response = await getAdminOrders();
        setOrders(response.data);
      } catch (error) {
        console.error(error);
      }
    };

    if (sellerId) {
      fetchOrders();
    }
  }, [sellerId]);

  const loadOrders = async () => {
    try {
      const response = await getAdminOrders();
      setOrders(response.data);
    } catch (error) {
      console.error(error);
    }
  };

  const handleDispatch = async (orderId) => {
    try {
      await updateAdminOrderStatus(orderId, { status: "DISPATCHED" });
      await loadOrders();
    } catch (error) {
      alert(error.response?.data?.message || "Failed to update status");
    }
  };

  return (
    <div style={styles.page}>
      <div style={styles.container}>
        <div style={styles.headerRow}>
          <div>
            <p style={styles.badge}>Seller Orders</p>
            <h1 style={styles.title}>Admin Orders</h1>
            <p style={styles.subtitle}>
              View customer orders related to your products and mark them as dispatched.
            </p>
          </div>

          <button style={styles.backButton} onClick={() => navigate("/admin-dashboard")}>
            Back to Dashboard
          </button>
        </div>

        {orders.length === 0 ? (
          <div style={styles.emptyCard}>
            <h3 style={styles.emptyTitle}>No paid orders yet</h3>
            <p style={styles.emptyText}>Orders will appear here after successful payment.</p>
          </div>
        ) : (
          <div style={styles.grid}>
            {orders.map((order) => (
              <div key={order.orderId} style={styles.card}>
                <h3 style={styles.orderCode}>{order.orderCode}</h3>
                <p style={styles.meta}>Status: {order.orderStatus}</p>
                <p style={styles.meta}>Total: Rs. {order.totalAmount}</p>
                <p style={styles.meta}>Buyer ID: {order.userId}</p>

                <div style={styles.itemsBox}>
                  {order.items.map((item) => (
                    <div key={item.itemId} style={styles.itemRow}>
                      <span style={styles.itemName}>{item.productName}</span>
                      <span style={styles.itemQty}>Qty: {item.quantity}</span>
                    </div>
                  ))}
                </div>

                {order.orderStatus === "PENDING_DISPATCH" && (
                  <button
                    style={styles.dispatchButton}
                    onClick={() => handleDispatch(order.orderId)}
                  >
                    Mark as Dispatched
                  </button>
                )}
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  );
}

