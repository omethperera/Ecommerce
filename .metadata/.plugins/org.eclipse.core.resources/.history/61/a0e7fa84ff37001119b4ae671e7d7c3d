import { useNavigate } from 'react-router-dom'
import { getUsername, clearAuthData } from '../utils/auth'

function UserDashboard() {
  const navigate = useNavigate()
  const username = getUsername()

  const handleLogout = () => {
    clearAuthData()
    navigate('/login')
  }

  return (
    <div style={styles.page}>
      <div style={styles.card}>
        <p style={styles.badge}>Buyer Dashboard</p>
        <h1 style={styles.title}>Welcome, {username || 'User'}</h1>
        <p style={styles.subtitle}>
          This is a placeholder user dashboard. Product browsing, cart, and order features will be added later.
        </p>

        <button style={styles.logoutButton} onClick={handleLogout}>
          Logout
        </button>
      </div>
    </div>
  )
}

