import { useEffect, useState } from "react";
import { getAdminOrders, updateAdminOrderStatus } from "../api/orderApi";

function AdminOrdersPage() {
  const [orders, setOrders] = useState([]);
  const sellerId = localStorage.getItem("sellerId");

  const loadOrders = async () => {
    try {
      const response = await getAdminOrders(sellerId);
      setOrders(response.data);
    } catch (error) {
      console.error(error);
    }
  };

  useEffect(() => {
    const fetchOrders = async () => {
      try {
        const response = await getAdminOrders(sellerId);
        setOrders(response.data);
      } catch (error) {
        console.error(error);
      }
    };

    fetchOrders();
  }, [sellerId]);

  const handleDispatch = async (orderId) => {
    try {
      await updateAdminOrderStatus(sellerId, orderId, { status: "DISPATCHED" });
      loadOrders();
    } catch (error) {
      alert(error.response?.data?.message || "Failed to update status");
    }
  };

  return (
    <div style={{ padding: "20px" }}>
      <h2>Admin Orders</h2>

      {orders.length === 0 ? (
        <p>No paid orders yet.</p>
      ) : (
        orders.map((order) => (
          <div
            key={order.orderId}
            style={{
              border: "1px solid #ccc",
              borderRadius: "8px",
              padding: "12px",
              marginBottom: "12px",
            }}
          >
            <h4>{order.orderCode}</h4>
            <p>Status: {order.orderStatus}</p>
            <p>Total: {order.totalAmount}</p>

            {order.items.map((item) => (
              <div key={item.itemId}>
                <p>
                  {item.productName} - Qty: {item.quantity}
                </p>
              </div>
            ))}

            {order.orderStatus === "PENDING_DISPATCH" && (
              <button onClick={() => handleDispatch(order.orderId)}>
                Mark as Dispatched
              </button>
            )}
          </div>
        ))
      )}
    </div>
  );
}

export default AdminOrdersPage;