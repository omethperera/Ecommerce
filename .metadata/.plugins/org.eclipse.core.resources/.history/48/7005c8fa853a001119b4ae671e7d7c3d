package com.ecommerce.paymentservice.service;

import com.ecommerce.paymentservice.client.OrderServiceClient;
import com.ecommerce.paymentservice.config.PayHereConfig;
import com.ecommerce.paymentservice.config.PayHereHashUtil;
import com.ecommerce.paymentservice.dto.OrderPaymentDetailsResponse;
import com.ecommerce.paymentservice.dto.PayHereNotifyRequest;
import com.ecommerce.paymentservice.dto.PayHerePaymentResponse;
import com.ecommerce.paymentservice.dto.PaymentFailedRequest;
import com.ecommerce.paymentservice.dto.PaymentInitiateRequest;
import com.ecommerce.paymentservice.dto.PaymentInitiateResponse;
import com.ecommerce.paymentservice.dto.PaymentResponse;
import com.ecommerce.paymentservice.dto.PaymentSuccessRequest;
import com.ecommerce.paymentservice.entity.Payment;
import com.ecommerce.paymentservice.enums.PaymentStatus;
import com.ecommerce.paymentservice.repository.PaymentRepository;
import org.springframework.stereotype.Service;


@Service
public class PaymentService {

    private final PaymentRepository paymentRepository;
    private final OrderServiceClient orderServiceClient;
    private final PayHereConfig payHereConfig;
    private final PayHereHashUtil payHereHashUtil;

    public PaymentService(PaymentRepository paymentRepository,
            OrderServiceClient orderServiceClient,
            PayHereConfig payHereConfig,
            PayHereHashUtil payHereHashUtil) {
this.paymentRepository = paymentRepository;
this.orderServiceClient = orderServiceClient;
this.payHereConfig = payHereConfig;
this.payHereHashUtil = payHereHashUtil;
}

    public PaymentResponse getPaymentByOrderId(Long orderId) {
        Payment payment = paymentRepository.findByOrderId(orderId).orElse(null);

        if (payment == null) {
            return null;
        }

        PaymentResponse response = new PaymentResponse();
        response.setId(payment.getId());
        response.setOrderId(payment.getOrderId());
        response.setUserId(payment.getUserId());
        response.setEmail(payment.getEmail());
        response.setAmount(payment.getAmount());
        response.setPaymentStatus(payment.getPaymentStatus().name());
        response.setGatewayName(payment.getGatewayName());
        response.setGatewayPaymentId(payment.getGatewayPaymentId());
        response.setCreatedAt(payment.getCreatedAt());
        response.setUpdatedAt(payment.getUpdatedAt());
        response.setPaidAt(payment.getPaidAt());

        return response;
    }

    public PayHerePaymentResponse initiatePayment(PaymentInitiateRequest request) {
        OrderPaymentDetailsResponse order = orderServiceClient.getOrderDetailsForPayment(request.getOrderId());

        if (order == null) {
            throw new RuntimeException("Order not found");
        }

        if (!"PENDING".equalsIgnoreCase(order.getPaymentStatus())) {
            throw new RuntimeException("Order payment status is not PENDING");
        }

        if (!"PENDING_PAYMENT".equalsIgnoreCase(order.getOrderStatus())) {
            throw new RuntimeException("Order is not in PENDING_PAYMENT state");
        }

        Payment existingPayment = paymentRepository.findByOrderId(request.getOrderId()).orElse(null);
        if (existingPayment != null) {
            throw new RuntimeException("Payment already exists for this order");
        }

        Payment payment = new Payment();
        payment.setOrderId(order.getOrderId());
        payment.setUserId(order.getUserId());
        payment.setEmail(request.getEmail());
        payment.setAmount(order.getTotalAmount());
        payment.setPaymentStatus(PaymentStatus.PENDING);
        payment.setGatewayName("PAYHERE");
        payment.setCreatedAt(java.time.LocalDateTime.now());
        payment.setUpdatedAt(java.time.LocalDateTime.now());

        Payment savedPayment = paymentRepository.save(payment);

        String orderReference = String.valueOf(savedPayment.getOrderId());

        String hash = payHereHashUtil.generateHash(
                payHereConfig.getMerchantId(),
                orderReference,
                savedPayment.getAmount(),
                payHereConfig.getCurrency(),
                payHereConfig.getMerchantSecret()
        );

        PayHerePaymentResponse response = new PayHerePaymentResponse();
        response.setPaymentId(savedPayment.getId());
        response.setOrderId(savedPayment.getOrderId());
        response.setMerchantId(payHereConfig.getMerchantId());
        response.setReturnUrl(payHereConfig.getReturnUrl());
        response.setCancelUrl(payHereConfig.getCancelUrl());
        response.setNotifyUrl(payHereConfig.getNotifyUrl());
        response.setFirstName("Customer");
        response.setLastName("User");
        response.setEmail(savedPayment.getEmail());
        response.setPhone("0771234567");
        response.setAddress("N/A");
        response.setCity("Colombo");
        response.setCountry("Sri Lanka");
        response.setOrderReference(orderReference);
        response.setAmount(savedPayment.getAmount());
        response.setCurrency(payHereConfig.getCurrency());
        response.setHash(hash);
        response.setCheckoutUrl(payHereConfig.getCheckoutUrl());

        return response;
    }
    
    public PaymentResponse markPaymentSuccess(PaymentSuccessRequest request) {
        Payment payment = paymentRepository.findByOrderId(request.getOrderId()).orElse(null);

        if (payment == null) {
            throw new RuntimeException("Payment not found for this order");
        }

        payment.setPaymentStatus(PaymentStatus.SUCCESS);
        payment.setGatewayPaymentId(request.getPaymentReference());
        payment.setPaidAt(java.time.LocalDateTime.now());
        payment.setUpdatedAt(java.time.LocalDateTime.now());

        Payment savedPayment = paymentRepository.save(payment);

        orderServiceClient.handlePaymentSuccess(request);

        PaymentResponse response = new PaymentResponse();
        response.setId(savedPayment.getId());
        response.setOrderId(savedPayment.getOrderId());
        response.setUserId(savedPayment.getUserId());
        response.setEmail(savedPayment.getEmail());
        response.setAmount(savedPayment.getAmount());
        response.setPaymentStatus(savedPayment.getPaymentStatus().name());
        response.setGatewayName(savedPayment.getGatewayName());
        response.setGatewayPaymentId(savedPayment.getGatewayPaymentId());
        response.setCreatedAt(savedPayment.getCreatedAt());
        response.setUpdatedAt(savedPayment.getUpdatedAt());
        response.setPaidAt(savedPayment.getPaidAt());

        return response;
    }
    
    public PaymentResponse markPaymentFailed(PaymentFailedRequest request) {
        Payment payment = paymentRepository.findByOrderId(request.getOrderId()).orElse(null);

        if (payment == null) {
            throw new RuntimeException("Payment not found for this order");
        }

        orderServiceClient.handlePaymentFailed(request);

        payment.setPaymentStatus(PaymentStatus.FAILED);
        payment.setUpdatedAt(java.time.LocalDateTime.now());

        Payment savedPayment = paymentRepository.save(payment);

        PaymentResponse response = new PaymentResponse();
        response.setId(savedPayment.getId());
        response.setOrderId(savedPayment.getOrderId());
        response.setUserId(savedPayment.getUserId());
        response.setEmail(savedPayment.getEmail());
        response.setAmount(savedPayment.getAmount());
        response.setPaymentStatus(savedPayment.getPaymentStatus().name());
        response.setGatewayName(savedPayment.getGatewayName());
        response.setGatewayPaymentId(savedPayment.getGatewayPaymentId());
        response.setCreatedAt(savedPayment.getCreatedAt());
        response.setUpdatedAt(savedPayment.getUpdatedAt());
        response.setPaidAt(savedPayment.getPaidAt());

        return response;
    }
    
    public String handlePayHereNotify(PayHereNotifyRequest request) {
        Long orderId = Long.valueOf(request.getOrderId());

        Payment payment = paymentRepository.findByOrderId(orderId).orElse(null);
        if (payment == null) {
            throw new RuntimeException("Payment not found for this order");
        }

        boolean valid = payHereHashUtil.isValidNotifySignature(
                request.getMerchantId(),
                request.getOrderId(),
                request.getPayhereAmount(),
                request.getPayhereCurrency(),
                request.getStatusCode(),
                request.getMd5sig(),
                payHereConfig.getMerchantSecret()
        );

        if (!valid) {
            throw new RuntimeException("Invalid PayHere signature");
        }

        if ("2".equals(request.getStatusCode())) {
            PaymentSuccessRequest successRequest = new PaymentSuccessRequest();
            successRequest.setOrderId(orderId);
            successRequest.setPaymentReference(request.getPaymentId());

            markPaymentSuccess(successRequest);
            return "Payment marked as SUCCESS";
        }

        return "PayHere notify verified";
    }
}